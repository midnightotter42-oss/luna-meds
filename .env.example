# Neon Postgres connection string (van Vercel Storage → Connect)
DATABASE_URL=postgres://...

# Gmail SMTP credentials voor reminder mails
# Maak een App Password aan via: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_PASSWORD=

# Email adres van Luna (waar reminders heen gaan)
LUNA_EMAIL=

# Optioneel: simpele token voor de cron endpoint
REMINDER_CRON_SECRET=
